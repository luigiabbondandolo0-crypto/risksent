# Copy to .env.local for local dev. On Vercel set these in Project → Settings → Environment Variables.

# Security / deployment
# - Never prefix secrets with NEXT_PUBLIC_ (they ship to the browser). Service role and DB URLs stay server-only.
# - Production: TLS is enforced at the edge; optional override: ENFORCE_HTTPS=false only for special local/proxy setups.
# ENFORCE_HTTPS=
# - Global API abuse (per IP, /api/* except webhooks/cron/health): default 120/min. Tune if needed.
# API_BURST_LIMIT_PER_MINUTE=120
# - Authenticated list endpoints (e.g. /api/accounts): requests per user per minute.
# API_LIST_BURST_PER_MINUTE=90
# - AI: coach chat (per user per hour), analyze (per user per day), insight stubs (per user per hour).
# RATE_LIMIT_AI_CHAT_PER_HOUR=40
# RATE_LIMIT_AI_ANALYZE_PER_DAY=12
# RATE_LIMIT_AI_INSIGHT_PER_HOUR=60
# - Backtesting OHLCV and journal uploads (per user / IP+user); see lib/security/apiAbuse.ts for env names.
# RATE_LIMIT_OHLCV_PER_MINUTE=45
# RATE_LIMIT_JOURNAL_UPLOAD_PER_MINUTE=20
# - Postgres: this app talks to Supabase via URL + keys, not a raw DATABASE_URL in the browser. In Supabase Dashboard →
#   Database → restrict public internet access to Postgres (prefer pooler / private networking); do not expose 5432 to 0.0.0.0/0.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL: use https://risksent.com on Vercel, http://localhost:3000 locally
NEXT_PUBLIC_SITE_URL=https://risksent.com

# Resend (welcome emails + trial-ending reminders sent by /api/cron/trial-reminder)
RESEND_API_KEY=

# Optional: encryption for stored credentials
ENCRYPTION_KEY=

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALERT_CHANNEL_ID=
TELEGRAM_WEBHOOK_BASE_URL=

# Optional: cron and bot
CRON_SECRET=
BOT_INTERNAL_SECRET=

# Twelve Data (backtesting OHLCV — https://twelvedata.com)
TWELVE_DATA_API_KEY=

# Analytics providers (loaded only when the user grants the matching cookie consent).
# Leave empty to skip entirely. Order of precedence when analytics consent is given:
# Plausible → GA4. Marketing consent gates Meta Pixel independently.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=risksent.com
# NEXT_PUBLIC_PLAUSIBLE_SRC=                     # optional self-hosted script URL
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=
