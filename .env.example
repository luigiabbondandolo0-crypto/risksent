# Copy to .env.local for local dev. On Vercel set these in Project → Settings → Environment Variables.

# Security / deployment
# - Never prefix secrets with NEXT_PUBLIC_ (they ship to the browser). Service role and DB URLs stay server-only.
# - Production: TLS is enforced at the edge; optional override: ENFORCE_HTTPS=false only for special local/proxy setups.
# ENFORCE_HTTPS=
# - Global API abuse (per IP, /api/* except webhooks/cron/health): default 120/min. Tune if needed.
# API_BURST_LIMIT_PER_MINUTE=120
# - Authenticated list endpoints (e.g. /api/accounts): requests per user per minute.
# API_LIST_BURST_PER_MINUTE=90
# - AI: coach chat (per user per hour), analyze (per user per day), insight stubs (per user per hour).
# RATE_LIMIT_AI_CHAT_PER_HOUR=40
# RATE_LIMIT_AI_ANALYZE_PER_DAY=12
# RATE_LIMIT_AI_INSIGHT_PER_HOUR=60
# - Backtesting OHLCV and journal uploads (per user / IP+user); see lib/security/apiAbuse.ts for env names.
# RATE_LIMIT_OHLCV_PER_MINUTE=45
# RATE_LIMIT_JOURNAL_UPLOAD_PER_MINUTE=20
# - Postgres: this app talks to Supabase via URL + keys, not a raw DATABASE_URL in the browser. In Supabase Dashboard →
#   Database → restrict public internet access to Postgres (prefer pooler / private networking); do not expose 5432 to 0.0.0.0/0.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL: use https://risksent.com on Vercel, http://localhost:3000 locally
NEXT_PUBLIC_SITE_URL=https://risksent.com

# Resend (transactional: signup, trial, billing, password, contact form, etc.)
RESEND_API_KEY=
# Override the "From" header. Must be an address on a domain verified in Resend.
# Display name is optional. Default: "RiskSent <info@risksent.com>".
# RESEND_FROM_EMAIL=RiskSent <info@risksent.com>
# Where user replies should go. Default: support@risksent.com.
# RESEND_REPLY_TO=support@risksent.com
# Inbox for /api/contact (defaults to support@risksent.com).
# SUPPORT_INBOX_EMAIL=support@risksent.com

# Encryption for stored MT passwords (32+ chars). Required for /api/add-account.
ENCRYPTION_KEY=

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALERT_CHANNEL_ID=
TELEGRAM_WEBHOOK_BASE_URL=

# Optional: cron and bot
CRON_SECRET=
BOT_INTERNAL_SECRET=

# Twelve Data (backtesting OHLCV — https://twelvedata.com)
TWELVE_DATA_API_KEY=

# MetaApi.cloud — provisioning + live stats (https://app.metaapi.cloud/token)
# METAAPI_TOKEN=
# Client REST API MUST match your account region or you get 504 TimeoutError. Copy the client API URL from:
# https://app.metaapi.cloud/api-access/api-urls
# (Default below is New York only — change if accounts are in London, Singapore, etc.)
# METAAPI_BASE_URL=https://mt-client-api-v1.new-york.agiliumtrade.ai
# Provisioning API (create/deploy account) — use the provisioning URL for the same region as above when needed.
# METAAPI_PROVISIONING_URL=https://mt-provisioning-api-v1.agiliumtrade.agiliumtrade.ai
# Optional: METAAPI_REGION=, METAAPI_PROVISIONING_PROFILE_ID= (if auto broker detection fails)
# Optional: METAAPI_RESOURCE_SLOTS=2 if MetaApi returns E_RESOURCE_SLOTS
# Optional: comma-separated broker hints for server search — METAAPI_BROKER_KEYWORDS=Raw Trading Ltd
# METAAPI_HISTORY_DAYS=1095

# Anthropic (AI Coach — claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Stripe (checkout, portal, webhooks)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_NEW_TRADER_PRICE_ID=   # Stripe Price for $30/mo USD (recurring)
# STRIPE_EXPERIENCED_PRICE_ID=   # Stripe Price for $45/mo USD (recurring)
# Optional: Billing Portal configuration ID from Stripe Dashboard (Products → Billing portal).
# Configure cancellation as "at end of billing period" so users keep access until current_period_end, then must resubscribe manually.
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_...
